# Configurações do PostgreSQL
# IMPORTANTE: ao alterar POSTGRES_PASSWORD em instalação existente,
# recrie o volume com `docker-compose down -v` ou atualize a senha no PostgreSQL manualmente.
POSTGRES_USER=myperson
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=myperson

# Configurações da API ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# JWT (mínimo 32 caracteres para JWT_KEY)
JWT_KEY=CHANGE_ME_JWT_SECRET_KEY_MIN_32_CHARS
JWT_ISSUER=MyPerson.Api
JWT_AUDIENCE=MyPerson

# Autenticação Admin
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# CORS (origens permitidas, separadas por vírgula)
# CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:4200
