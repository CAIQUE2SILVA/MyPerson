# ===== PRODUÇÃO — copie para .env.prod e preencha =====

# PostgreSQL (use senhas fortes e únicas)
POSTGRES_USER=myperson_prod
POSTGRES_PASSWORD=TROQUE_PARA_SENHA_FORTE_AQUI
POSTGRES_DB=myperson

# JWT (mínimo 32 caracteres, gerado aleatoriamente)
JWT_KEY=GERE_UMA_CHAVE_ALEATORIA_AQUI_COM_PELO_MENOS_32_CHARS
JWT_ISSUER=MyPerson.Api
JWT_AUDIENCE=MyPerson

# Admin credentials
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=TROQUE_PARA_SENHA_FORTE_AQUI

# CORS — domínios reais do frontend e admin
CORS_ORIGIN_FRONTEND=https://seudominio.com
CORS_ORIGIN_ADMIN=https://admin.seudominio.com
